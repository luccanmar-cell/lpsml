{
  "dataset_path": "tarifacompleto_clean.parquet",
  "target_column": "Prima",
  "component_target_columns": [
    "PrimaRC",
    "PrimaCasco",
    "PrimaClausulaAjuste",
    "PrimaAccesorio"
  ],
  "final_weight": 0.5,
  "identity_column": "NroPoliza",
  "output_directory": "training_runs",
  "mape_group_columns": {
    "Cobertura": "CoberturaLabel",
    "Pol6TTaCod": "Pol6TTaCod"
  },
  "drop_columns": [
    "NroPoliza",
    "CoberturaLabel",
    "Pol6TTaCod"
  ],
  "test_size": 0.2,
  "random_state": 42,
  "search": {
    "method": "grid",
    "n_trials": 8,
    "trial_n_jobs": 4,
    "timeout_seconds": null,
    "show_progress_bar": false
  },
  "cv": {
    "n_splits": 3,
    "shuffle": true,
    "n_jobs": -1
  },
  "models": [
    {
      "name": "Random forest",
      "type": "random_forest",
      "scalers": [
        "none"
      ],
      "fixed_params": {
        "random_state": 42,
        "n_jobs": -1
      },
      "param_grid": {
        "n_estimators": [
          200,
          400
        ],
        "max_depth": [
          null,
          12,
          24
        ],
        "min_samples_leaf": [
          1,
          3
        ]
      },
      "optuna_space": {
        "n_estimators": {
          "type": "int",
          "low": 100,
          "high": 500,
          "step": 50
        },
        "max_depth": {
          "type": "categorical",
          "choices": [
            null,
            8,
            12,
            20,
            30
          ]
        },
        "min_samples_leaf": {
          "type": "int",
          "low": 1,
          "high": 6
        }
      }
    },
    {
      "name": "Histogram gradient boosting",
      "type": "hist_gradient_boosting",
      "scalers": [
        "none"
      ],
      "fixed_params": {
        "random_state": 42,
        "l2_regularization": 0.1
      },
      "param_grid": {
        "learning_rate": [
          0.04,
          0.08
        ],
        "max_iter": [
          200,
          350
        ],
        "max_leaf_nodes": [
          15,
          31
        ]
      },
      "optuna_space": {
        "learning_rate": {
          "type": "float",
          "low": 0.02,
          "high": 0.15,
          "log": true
        },
        "max_iter": {
          "type": "int",
          "low": 150,
          "high": 500,
          "step": 50
        },
        "max_leaf_nodes": {
          "type": "categorical",
          "choices": [
            15,
            31,
            63
          ]
        },
        "l2_regularization": {
          "type": "float",
          "low": 0.0001,
          "high": 10.0,
          "log": true
        }
      }
    },
    {
      "name": "Extra trees",
      "type": "extra_trees",
      "scalers": [
        "none"
      ],
      "fixed_params": {
        "random_state": 42,
        "n_jobs": -1
      },
      "param_grid": {
        "n_estimators": [
          200,
          400
        ],
        "max_depth": [
          null,
          15
        ],
        "min_samples_leaf": [
          1,
          3
        ]
      },
      "optuna_space": {
        "n_estimators": {
          "type": "int",
          "low": 100,
          "high": 500,
          "step": 50
        },
        "max_depth": {
          "type": "categorical",
          "choices": [
            null,
            8,
            10,
            15,
            25
          ]
        },
        "min_samples_leaf": {
          "type": "int",
          "low": 1,
          "high": 6
        }
      }
    }
  ]
}
